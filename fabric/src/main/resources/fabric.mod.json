{
	"schemaVersion": 1,
	"id": "${modId}",
	"version": "${modVersion}",
	"name": "${modName}",
	"description": "${modDescription}",
	"authors": [
		"GrilledHam"
	],
	"contact": {
		"homepage": "${modHomepage}",
		"sources": "${modSources}",
		"issues": "${modIssues}"
	},
	"license": "${modLicense}",
	"icon": "assets/iceball/icon.png",

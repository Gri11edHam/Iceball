			"net.grilledham.iceball.fabric.ClientEntrypoint"
		],
		"main": [
			"net.grilledham.iceball.fabric.Entrypoint"
		]
	},
	"mixins": [
		"iceball.mixins.json"
	],
	"accessWidener": "${modId}.accesswidener",
	"depends": {
		"fabricloader": "*",
		"fabric-api": "*",
		"minecraft": "${mcCompatFabric}"
	}
